# LLM API 配置
LLM_API_KEY=your_api_key_here
LLM_API_URL=https://api.minimaxi.com/v1
LLM_CHAT_URL=https://api.minimaxi.com/v1/chat/completions
LLM_TEXT_URL=https://api.minimaxi.com/v1/text/chatcompletion_v2
LLM_LYRICS_URL=https://api.minimaxi.com/v1/lyrics_generation
LLM_MUSIC_URL=https://api.minimaxi.com/v1/music_generation

# 模型配置
LLM_LYRICS_MODEL=MiniMax-M2.7
LLM_CHAT_MODEL=MiniMax-M2.7
LLM_MUSIC_MODEL=music-2.6

# Server 配置
PORT=3001
HOST=0.0.0.0

# 可选：默认 Provider（默认 minimax，可扩展）
# DEFAULT_PROVIDER=minimax
